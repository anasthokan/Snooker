# GameHub Pro Backend - Environment Configuration
# Copy to .env and adjust values.

# Application
APP_NAME=GameHub Pro API
# DEBUG=true: forgot-password returns reset_token in response (for testing without email)
DEBUG=false
# DB_PASSWORD=@Fardeen8177
# Database (PostgreSQL)
# Option A: Full URL (special chars in password: @ = %40, # = %23)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/gamehub
# Option B: Separate vars (recommended - no encoding issues)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gamehub
DB_USER=postgres
DB_PASSWORD=Fardeen8177
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# JWT (use a long random secret in production)
JWT_SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
BCRYPT_ROUNDS=12

# CORS (comma-separated origins for React frontend)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://74.208.184.175:8010

# Moyasar payment gateway (SAR) — get keys from https://moyasar.com
MOYASAR_PUBLISHABLE_KEY=pk_test_your_publishable_key
MOYASAR_SECRET_KEY=sk_test_your_secret_key
# Public URL customers use to pay online (share this link)
PUBLIC_APP_URL=http://74.208.184.175:8010

# Optional: seed script
ADMIN_EMAIL=admin@gamehub.local
ADMIN_PASSWORD=Admin@123
